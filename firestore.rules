rules_version = '2';

// Siruvani Bar & Kitchen ERP — Firestore security rules
// Every document lives under users/{uid}/... and is private to that user.
service cloud.firestore {
  match /databases/{database}/documents {

    // The user's profile document: users/{uid}
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // All sub-collections (sales, expenses, purchases, stock, settings, ...)
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
