rules_version = '2';

// Siruvani Bar & Kitchen ERP — Storage security rules
// Files are stored under {uid}/{scope}/{filename} and are private to that user.
service firebase.storage {
  match /b/{bucket}/o {
    match /{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
